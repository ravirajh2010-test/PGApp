# Backend Production Environment Variables
# These will be set in Render dashboard during deployment

NODE_ENV=production
PORT=5000

# Database (will be set automatically by Render PostgreSQL)
# DATABASE_URL will be auto-generated by Render

# JWT Secret (will be auto-generated by Render)
# JWT_SECRET will be auto-generated by Render

# Email Configuration (Set these in Render dashboard)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password

# Razorpay Configuration (Set these in Render dashboard)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Frontend URL (will be auto-set by Render from frontend service)
FRONTEND_URL=https://your-frontend-url.onrender.com
